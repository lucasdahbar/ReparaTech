generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum StatusOrdemServico {
  ABERTA
  EM_ORCAMENTO
  AGUARDANDO_PECAS
  EM_MANUTENCAO
  PRONTA_PARA_RETIRADA
  FINALIZADA
}

enum PerfilUsuario {
  ATENDENTE
  TECNICO
  CLIENTE
  ADMIN
}

enum TipoMovimentoEstoque {
  ENTRADA
  SAIDA
  AJUSTE
}

model Cliente {
  id            String         @id @default(cuid())
  nome          String
  documento     String?        @unique
  telefone      String?
  email         String?        @unique
  endereco      String?
  aparelhos     Aparelho[]
  ordensServico OrdemServico[]
  usuarios      Usuario[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([nome])
  @@map("clientes")
}

model Usuario {
  id         String        @id @default(cuid())
  nome       String
  email      String        @unique
  senhaHash  String
  perfil     PerfilUsuario @default(ATENDENTE)
  clienteId  String?       @unique
  cliente    Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ativo      Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("usuarios")
}

model Aparelho {
  id              String         @id @default(cuid())
  clienteId       String
  cliente         Cliente        @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  marca           String
  modelo          String
  numeroSerie     String?        @unique
  imei            String?        @unique
  defeitoRelatado  String?
  ordensServico   OrdemServico[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clienteId])
  @@map("aparelhos")
}

model OrdemServico {
  id                String               @id @default(cuid())
  numero            String               @unique
  clienteId         String
  aparelhoId        String
  cliente           Cliente              @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  aparelho          Aparelho             @relation(fields: [aparelhoId], references: [id], onDelete: Restrict)
  status            StatusOrdemServico   @default(ABERTA)
  descricaoEntrada  String
  observacaoTecnica String?
  valorOrcamento    Decimal?             @db.Decimal(10, 2)
  valorMaoDeObra    Decimal?             @db.Decimal(10, 2)
  retiradaAutorizada Boolean              @default(false)
  dataAbertura      DateTime             @default(now())
  dataFechamento    DateTime?
  pecas             OrdemServicoPeca[]
  movimentosEstoque MovimentoEstoque[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([clienteId])
  @@index([aparelhoId])
  @@index([status])
  @@map("ordens_servico")
}

model PecaEstoque {
  id            String              @id @default(cuid())
  nome          String
  sku           String              @unique
  descricao     String?
  quantidade    Int                 @default(0)
  custoUnitario Decimal             @db.Decimal(10, 2)
  precoVenda    Decimal?            @db.Decimal(10, 2)
  itensOS       OrdemServicoPeca[]
  movimentos    MovimentoEstoque[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([nome])
  @@map("pecas_estoque")
}

model OrdemServicoPeca {
  id             String        @id @default(cuid())
  ordemServicoId  String
  pecaId         String
  quantidade     Int
  valorUnitario   Decimal       @db.Decimal(10, 2)
  ordemServico   OrdemServico  @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  peca           PecaEstoque   @relation(fields: [pecaId], references: [id], onDelete: Restrict)
  createdAt      DateTime      @default(now())

  @@unique([ordemServicoId, pecaId])
  @@index([ordemServicoId])
  @@index([pecaId])
  @@map("ordens_servico_pecas")
}

model MovimentoEstoque {
  id             String               @id @default(cuid())
  pecaId         String
  ordemServicoId  String?
  tipo           TipoMovimentoEstoque
  quantidade     Int
  motivo         String?
  peca           PecaEstoque          @relation(fields: [pecaId], references: [id], onDelete: Restrict)
  ordemServico   OrdemServico?        @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now())

  @@index([pecaId])
  @@index([ordemServicoId])
  @@map("movimentos_estoque")
}
